# Ad Intelligence Pipeline — Environment Variables
# Copy this to .env and fill in your keys

# Groq API (Primary LLM) — Get free key at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Google Gemini (Fallback LLM) — Get free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# HuggingFace (BLIP-2 Inference API) — Get free token at https://huggingface.co/settings/tokens
HF_API_TOKEN=your_huggingface_token_here
